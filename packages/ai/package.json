{
	"name": "@gerred/npi-ai",
	"version": "0.1.0",
	"description": "Noumena-focused LLM API for npi",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./openai-completions": {
			"types": "./dist/providers/openai-completions.d.ts",
			"import": "./dist/providers/openai-completions.js"
		},
		"./oauth": {
			"types": "./dist/oauth.d.ts",
			"import": "./dist/oauth.js"
		}
	},
	"bin": {
		"npi-ai": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist native/openai-compat-ws-v2-napi/dist",
		"generate-models": "node scripts/generate-models.ts",
		"generate-image-models": "node scripts/generate-image-models.ts",
		"build": "npm run generate-models && npm run generate-image-models && tsgo -p tsconfig.build.json && npm run build:noumena-ws-v2-native",
		"build:noumena-ws-v2-native": "node scripts/build-noumena-ws-v2-native.mjs",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@opentelemetry/api": "1.9.0",
		"@smithy/node-http-handler": "4.7.3",
		"http-proxy-agent": "7.0.2",
		"https-proxy-agent": "7.0.6",
		"openai": "6.26.0",
		"partial-json": "0.1.7",
		"typebox": "1.1.38"
	},
	"keywords": [
		"noumena",
		"kimi",
		"coding-agent",
		"llm",
		"api"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gerred/npi.git",
		"directory": "packages/ai"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"devDependencies": {
		"@types/node": "24.12.4",
		"canvas": "3.2.3",
		"vitest": "3.2.6"
	}
}
